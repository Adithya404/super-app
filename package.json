    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "lint-staged": "^16.3.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
