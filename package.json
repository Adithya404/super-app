{
  "name": "super-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "pnpm migrate && next start",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check .",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/db/run-migrations.ts",
    "migrate:create": "tsx src/db/create-migration.ts"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "biome check --write"
    ]
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "next": "16.1.6",
    "pg": "^8.20.0",
    "pnpm": "^10.32.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "lint-staged": "^16.3.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
